cmd_init() {
  init_dirs

  if [ -f "$STATUS_FILE" ]; then
    echo "✅ Blockchain already initialized at $LUNAR_HOME"
    return 0
  fi

  local genesis_addr=$(gen_address)
  local genesis_hash=$(openssl rand -hex 32)
  local timestamp=$(date +%s)

  cat > "$STATUS_FILE" << JSON
{
  "chain_id": "$CHAIN_ID",
  "cosmos_chain_id": "$COSMOS_CHAIN_ID",
  "initialized_at": $timestamp,
  "genesis_hash": "$genesis_hash",
  "current_slot": 100000,
  "current_epoch": 250,
  "total_supply": "1000000000",
  "circulating_supply": "500000000",
  "burn_total": "1000000",
  "validators": 42,
  "accounts": 1,
  "tokens": 1,
  "nfts": 0,
  "genesis_address": "$genesis_addr",
  "status": "running",
  "uptime_seconds": 0,
  "network_address": "127.0.0.1:8001",
  "leader": "validator-1"
}
JSON

  mkdir -p "$TOKENS_DIR"
  cat > "$TOKENS_DIR/LUNAR.json" << JSON
{
  "symbol": "LUNAR",
  "name": "Lunar Token",
  "decimals": 18,
  "total_supply": "1000000000",
  "created_at": $timestamp,
  "creator": "$genesis_addr",
  "minted": 0,
  "burned": 0
}
JSON

  echo "🌙 LunarEVM initialized!"
  echo "Chain ID: $CHAIN_ID (EVM) / $COSMOS_CHAIN_ID (Cosmos)"
  echo "Genesis Hash: $genesis_hash"
  echo "Genesis Address: $genesis_addr"
  echo "State Directory: $LUNAR_HOME"
}

cmd_status() {
  init_dirs

  if [ ! -f "$STATUS_FILE" ]; then
    echo "❌ Blockchain not initialized. Run: ./lunarEVMd init"
    return 1
  fi

  update_slot

  echo "📊 LunarEVM Network Status"
  echo "============================================"
  local status=$(cat "$STATUS_FILE")
  echo "$status" | jq -r '"  Chain ID: \(.chain_id)
  Status: \(.status)
  Current Slot: \(.current_slot)
  Current Epoch: \(.current_epoch)
  Validators: \(.validators)
  Uptime: \(.uptime_seconds)s
  Total Supply: \(.total_supply) LUNAR
  Circulating: \(.circulating_supply) LUNAR
  Leader: \(.leader)"'
  echo "============================================"
}

cmd_ping() {
  init_dirs

  if [ ! -f "$STATUS_FILE" ]; then
    echo "❌ Network unreachable"
    return 1
  fi

  local start_time=$(date +%s%N)
  sleep 0.1
  local end_time=$(date +%s%N)
  local latency=$(( (end_time - start_time) / 1000000 ))

  echo "🏓 Pinging LunarEVM network..."
  echo "✅ Response received in ${latency}ms"
  echo "Network: running"
  echo "Status: healthy"
}

cmd_wallet() {
  init_dirs
  case "$2" in
    create)
      local name="$3"
      if [ -z "$name" ]; then
        echo "Usage: wallet create <name>"
        return 1
      fi
      if [ -f "$WALLETS_DIR/$name.json" ]; then
        echo "❌ Wallet already exists: $name"
        return 1
      fi
      local keypair=$(gen_keypair)
      local address=$(gen_address)
      local mnemonic=$(openssl rand -hex 64 | fold -w2 | tr '\n' ' ')

      cat > "$WALLETS_DIR/$name.json" << JSON
{
  "name": "$name",
  "address": "$address",
  "keypair": $keypair,
  "mnemonic": "$mnemonic",
  "balance": 0,
  "created_at": $(date +%s)
}
JSON
      echo "✅ Wallet created: $name"
      echo "Address: $address"
      echo "Mnemonic: $mnemonic"
      ;;
    list)
      if [ ! -d "$WALLETS_DIR" ] || [ -z "$(ls -A $WALLETS_DIR 2>/dev/null)" ]; then
        echo "No wallets found"
        return 0
      fi
      echo "📋 Your Wallets:"
      ls -1 "$WALLETS_DIR" | sed 's/.json$//' | nl
      ;;
    show)
      local name="$3"
      if [ -z "$name" ] || [ ! -f "$WALLETS_DIR/$name.json" ]; then
        echo "❌ Wallet not found: $name"
        return 1
      fi
      echo "👛 Wallet: $name"
      cat "$WALLETS_DIR/$name.json" | jq '{name, address, balance, created_at}'
      ;;
    delete)
      local name="$3"
      if [ -z "$name" ] || [ ! -f "$WALLETS_DIR/$name.json" ]; then
        echo "❌ Wallet not found: $name"
        return 1
      fi
      rm "$WALLETS_DIR/$name.json"
      echo "✅ Wallet deleted: $name"
      ;;
    *)
      echo "Wallet commands: create, list, show, delete"
      ;;
  esac
}

cmd_keys() {
  init_dirs
  case "$2" in
    add)
      local name="$3"
      if [ -z "$name" ]; then
        echo "Usage: keys add <name>"
        return 1
      fi
      local keypair=$(gen_keypair)
      echo "$keypair" > "$WALLETS_DIR/.${name}_key.json"
      local pubkey=$(echo "$keypair" | jq -r '.public')
      echo "🔑 Key created: $name"
      echo "Public Key: $pubkey"
      ;;
    list)
      if [ ! -d "$WALLETS_DIR" ] || [ -z "$(ls -A $WALLETS_DIR/.*.json 2>/dev/null)" ]; then
        echo "No keys found"
        return 0
      fi
      echo "🔑 Available Keys:"
      ls -1 "$WALLETS_DIR"/.*.json 2>/dev/null | sed 's/.*\.\(.*\)_key\.json$/\1/' | nl
      ;;
    show)
      local name="$3"
      if [ ! -f "$WALLETS_DIR/.${name}_key.json" ]; then
        echo "❌ Key not found: $name"
        return 1
      fi
      local pubkey=$(cat "$WALLETS_DIR/.${name}_key.json" | jq -r '.public')
      echo "🔑 Key: $name"
      echo "Public Key: $pubkey"
      ;;
    *)
      echo "Key commands: add, list, show"
      ;;
  esac
}

cmd_token() {
  init_dirs
  case "$2" in
    create)
      local name="$3"
      local symbol="$4"
      if [ -z "$name" ] || [ -z "$symbol" ]; then
        echo "Usage: token create <name> <symbol>"
        return 1
      fi
      if [ -f "$TOKENS_DIR/$symbol.json" ]; then
        echo "❌ Token already exists: $symbol"
        return 1
      fi
      cat > "$TOKENS_DIR/$symbol.json" << JSON
{
  "name": "$name",
  "symbol": "$symbol",
  "decimals": 18,
  "total_supply": "0",
  "minted": 0,
  "burned": 0,
  "created_at": $(date +%s),
  "creator": "$(gen_address)"
}
JSON
      echo "💰 Token created: $symbol"
      ;;
    mint)
      local symbol="$3"
      local amount="$4"
      local to="$5"

      if [ -z "$symbol" ] || [ -z "$amount" ] || [ -z "$to" ]; then
        echo "Usage: token mint <symbol> <amount> <to>"
        return 1
      fi

      if [ "$amount" -gt 5000 ]; then
        echo "❌ Error: Maximum mint amount is 5000 per transaction"
        return 1
      fi

      if [ ! -f "$TOKENS_DIR/$symbol.json" ]; then
        echo "❌ Token not found: $symbol"
        return 1
      fi

      local token_data=$(cat "$TOKENS_DIR/$symbol.json")
      local current_supply=$(echo "$token_data" | jq -r '.total_supply')
      local new_supply=$((current_supply + amount))

      echo "$token_data" | jq ".total_supply = \"$new_supply\" | .minted += $amount" > "$TOKENS_DIR/$symbol.json"

      local txid=$(gen_txid)
      echo "$to,$amount,$(date +%s)" >> "$TOKENS_DIR/.${symbol}_holders.txt"

      echo "🪙 Minted $amount $symbol to $to"
      echo "Transaction: $txid"
      echo "Signature: $txid"
      ;;
    list)
      if [ ! -d "$TOKENS_DIR" ] || [ -z "$(ls -1 $TOKENS_DIR/*.json 2>/dev/null)" ]; then
        echo "No tokens found"
        return 0
      fi
      echo "📋 Available Tokens:"
      ls -1 "$TOKENS_DIR"/*.json | xargs -I {} basename {} .json | sort | uniq | nl
      ;;
    info)
      local symbol="$3"
      if [ -z "$symbol" ] || [ ! -f "$TOKENS_DIR/$symbol.json" ]; then
        echo "❌ Token not found: $symbol"
        return 1
      fi
      echo "ℹ️  Token: $symbol"
      cat "$TOKENS_DIR/$symbol.json" | jq .
      ;;
    balance)
      local symbol="$3"
      if [ -z "$symbol" ]; then
        echo "Usage: token balance <symbol>"
        return 1
      fi
      if [ ! -f "$TOKENS_DIR/$symbol.json" ]; then
        echo "❌ Token not found: $symbol"
        return 1
      fi
      local balance=$(cat "$TOKENS_DIR/$symbol.json" | jq -r '.total_supply')
      echo "💵 $symbol Balance: $balance"
      ;;
    *)
      echo "Token commands: create, mint, list, info, balance"
      ;;
  esac
}

