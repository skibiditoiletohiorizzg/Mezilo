    show)
      echo "⚙️  Configuration"
      echo "  Chain ID (EVM): $CHAIN_ID"
      echo "  Chain ID (Cosmos): $COSMOS_CHAIN_ID"
      echo "  Home: $LUNAR_HOME"
      echo "  RPC (EVM): http://localhost:8545"
      echo "  RPC (Solana): http://localhost:8899"
      echo "  Network: 127.0.0.1:8001"
      ;;
    *)
      echo "Config commands: set, get, show"
      ;;
  esac
}

case "$1" in
  init)
    cmd_init
    ;;
  status)
    cmd_status
    ;;
  ping)
    cmd_ping
    ;;
  version)
    echo "🌙 LunarEVM v1.0.0"
    echo "Chain ID: $CHAIN_ID (EVM) / $COSMOS_CHAIN_ID (Cosmos)"
    echo "Consensus: PoS + PoH"
    ;;
  wallet)
    cmd_wallet "$@"
    ;;
  keys|key)
    cmd_keys "$@"
    ;;
  token)
    cmd_token "$@"
    ;;
  nft)
    cmd_nft "$@"
    ;;
  account)
    cmd_account "$@"
    ;;
  balance)
    cmd_balance "$@"
    ;;
  transaction|tx)
    cmd_transaction "$@"
    ;;
  airdrop)
    cmd_airdrop "$@"
    ;;
  supply)
    cmd_supply
    ;;
  inflation)
    cmd_inflation
    ;;
  rent)
    cmd_rent
    ;;
  blockhash)
    cmd_blockhash
    ;;
  genesis-hash)
    cmd_genesis_hash
    ;;
  block)
    cmd_block "$@"
    ;;
  epoch)
    cmd_epoch
    ;;
  slots)
    cmd_slots "$@"
    ;;
  leader-schedule)
    cmd_leader_schedule
    ;;
  pubkey)
    echo "🔑 Public Key: lunarpub1$(openssl rand -hex 19)"
    ;;
  address)
    case "$2" in
      generate)
        echo "🔑 Generated Address: $(gen_address)"
        ;;
      *)
        echo "Address commands: generate"
        ;;
    esac
    ;;
  pay)
    echo "💸 Paying $3 LUNAR to $2"
