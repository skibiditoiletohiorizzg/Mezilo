  echo "📅 Epoch Information"
  echo "============================================"
  echo "  Current Epoch: $epoch_slot"
  echo "  Epoch Start Slot: $((epoch_slot * 432000))"
  echo "  Epoch End Slot: $(((epoch_slot + 1) * 432000 - 1))"
  echo "  Current Slot: $slot"
  echo "  Progress: ${progress}%"
  echo "  Slots in Epoch: 432000"
  echo "  Leader Rotation: every 4 slots"
  echo "============================================"
}

