cmd_transaction() {
  case "$2" in
    send)
      local to="$3"
      local amount="$4"
      if [ -z "$to" ] || [ -z "$amount" ]; then
        echo "Usage: transaction send <to> <amount>"
        return 1
      fi
      local txid=$(gen_txid)
      mkdir -p "$TXNS_DIR"
      cat > "$TXNS_DIR/$txid.json" << JSON
{
  "txid": "$txid",
  "to": "$to",
  "amount": $amount,
  "timestamp": $(date +%s),
  "status": "confirmed",
  "confirmations": 32
}
JSON
      echo "💸 Sending $amount LUNAR to $to"
      echo "Transaction ID: $txid"
      echo "✅ Transaction confirmed"
      ;;
    status)
      local txid="$3"
      if [ -z "$txid" ]; then
        echo "Usage: transaction status <txid>"
        return 1
      fi
      if [ -f "$TXNS_DIR/$txid.json" ]; then
        local status=$(cat "$TXNS_DIR/$txid.json" | jq -r '.status')
        local confirmations=$(cat "$TXNS_DIR/$txid.json" | jq -r '.confirmations')
        echo "📊 Transaction: $txid"
        echo "Status: $status"
        echo "Confirmations: $confirmations"
      else
        echo "❌ Transaction not found: $txid"
      fi
      ;;
    history)
      if [ ! -d "$TXNS_DIR" ]; then
        echo "No transactions found"
        return 0
      fi
      echo "📝 Transaction History:"
      ls -1 "$TXNS_DIR" | nl
      ;;
    *)
      echo "Transaction commands: send, status, history"
      ;;
  esac
}

